ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=finance_tracker;Username=postgres;Password=postgres
Jwt__Issuer=FinanceTracker.Api
Jwt__Audience=FinanceTracker.Frontend
Jwt__SigningKey=replace-with-a-random-64-character-secret
Jwt__AccessTokenLifetimeMinutes=15
Jwt__RefreshTokenLifetimeDays=14
Jwt__RefreshCookieName=ft_refresh
Jwt__RequireHttpsMetadata=false
Frontend__AllowedOrigins__0=https://localhost:5173
Frontend__AllowedOrigins__1=http://localhost:5173
