{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=finance_tracker;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "FinanceTracker.Api",
    "Audience": "FinanceTracker.Frontend",
    "SigningKey": "replace-this-in-environment-with-a-64-char-secret-key",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 14,
    "RefreshCookieName": "ft_refresh",
    "RequireHttpsMetadata": true
  },
  "Frontend": {
    "AllowedOrigins": [
      "https://localhost:5173",
      "http://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
